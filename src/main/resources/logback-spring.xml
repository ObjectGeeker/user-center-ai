<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds" debug="false">
    <!-- 引入 Spring Boot 默认的基础配置 (包含默认转换规则等) -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />

    <!-- 定义变量 -->
    <!-- 应用名称，对应 spring.application.name，如果没有配置则默认为 spring-boot -->
    <property name="APP_NAME" value="my-project" />
    <!-- 日志存储路径 -->
    <property name="LOG_PATH" value="${LOG_PATH:-./logs}"/>
    <!-- 单个文件最大大小 -->
    <property name="MAX_FILE_SIZE" value="100MB"/>
    <!-- 日志保留天数 -->
    <property name="MAX_HISTORY" value="30"/>

    <!-- 定义控制台输出格式 -->
    <!-- 使用 Spring Boot 默认的 CONSOLE_LOG_PATTERN -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>utf8</charset>
        </encoder>
    </appender>

    <!-- 定义 INFO 级别日志文件 -->
    <appender name="FILE_INFO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前日志文件路径 -->
        <file>${LOG_PATH}/${APP_NAME}-info.log</file>
        <!-- 滚动策略：基于时间和大小 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-info.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 单个文件最大 100MB，超过则切分 -->
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <!-- 保留 30 天 -->
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <!-- 总日志大小限制 (可选，防止磁盘爆满) -->
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>utf8</charset>
        </encoder>
        <!-- 过滤器：只记录 INFO 及以上，且排除 ERROR (ERROR 单独记录) -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- 定义 ERROR 级别日志文件 (单独归档，方便排查) -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>utf8</charset>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- 环境区分配置 -->
    <!-- 开发环境：只输出控制台 -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
        <!-- 第三方包日志级别调整 -->
        <logger name="org.springframework.web" level="DEBUG"/>
    </springProfile>

    <!-- 生产环境：输出控制台 + 文件 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>

    <!-- 默认环境 (无指定 profile 时) -->
    <springProfile name="!prod &amp; !dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE_INFO" />
            <appender-ref ref="FILE_ERROR" />
        </root>
    </springProfile>

</configuration>